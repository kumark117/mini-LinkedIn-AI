# Use the password you set for the "postgres" user during PostgreSQL installation.
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/mini-linkedin-AI"
JWT_SECRET="dev_change_me_super_secret"

# Python service base URL (used by Next.js proxy routes)
FASTAPI_BASE_URL="http://localhost:8000"

# Used by FastAPI for OpenAI calls
OPENAI_API_KEY="dev_openai_key_placeholder"
# Optional: max tries per LLM call (initial + retries on 429 / 5xx / network). Default 4.
# OPENAI_MAX_ATTEMPTS=4
# LangGraph feed curator: how many times each LLM *node* may run (graph loop + backoff). Default 4.
# LANGGRAPH_LLM_TRIES=4
# Optional: protect FastAPI POST /internal/broadcast-post (must match frontend SSE_BROADCAST_SECRET)
# SSE_BROADCAST_SECRET=

