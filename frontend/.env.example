# Copy to .env and adjust. Do not commit .env.

# PostgreSQL (encode "!" in password as %21 in the URL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD%21@localhost:5432/mini-linkedin-AI"

# JWT for auth cookies
JWT_SECRET="change_me"

# Optional: AI features
FASTAPI_BASE_URL="http://localhost:8000"
OPENAI_API_KEY=""

# Database reset UI + API (/admin/reset-db). Demo only — disable in any shared or production deploy.
DB_RESET_PASSWORD="your_reset_password"
ALLOW_DB_RESET="false"
