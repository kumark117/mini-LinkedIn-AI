# Copy to .env and adjust. Do not commit .env.

# PostgreSQL (encode "!" in password as %21 in the URL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD%21@localhost:5432/mini-linkedin-AI"

# JWT for auth cookies
JWT_SECRET="change_me"

# Optional: AI features
# Prefer 127.0.0.1 for clarity on Windows; Next also maps localhost → IPv4 for server-side fetch.
FASTAPI_BASE_URL="http://127.0.0.1:8000"
# Browser SSE for new posts (FastAPI). Live headlines use same-origin /api/news/demo → FastAPI (no CORS).
NEXT_PUBLIC_FASTAPI_SSE_ORIGIN="http://127.0.0.1:8000"
# Optional shared secret for POST /internal/broadcast-post (set same value in repo-root .env for Python)
# SSE_BROADCAST_SECRET=""
OPENAI_API_KEY=""

# Database reset UI + API (/admin/reset-db). Demo only — disable in any shared or production deploy.
DB_RESET_PASSWORD="your_reset_password"
ALLOW_DB_RESET="false"

# Set to "false" to stop the HeartBeat bot from posting a server timestamp every minute (custom server only).
# HEARTBEAT_PULSE="false"
